oci_connection = {
  tenancy_ocid     = "<YOUR_TENANCY_OCID>"   # ocid1.tenancy.oc1..xxxx
  user_ocid        = "<YOUR_USER_OCID>"       # ocid1.user.oc1..xxxx
  fingerprint      = "<YOUR_API_KEY_FINGERPRINT>"
  private_key_path = "~/.oci/oci_api_key.pem"
  region           = "<YOUR_REGION>"          # e.g. eu-frankfurt-1, us-phoenix-1
}

# availability_domain controls which OCI AD to target (1, 2, or 3).
# Override per-run with: terraform apply -var="availability_domain=2"
# The hunt.sh script cycles through all ADs automatically.
availability_domain = 1

general = {
  compartment_name    = "mamsoft"
  main_network_cidr   = "172.16.0.0/16"
  private_subnet_cidr = "172.16.0.0/24"
}

vm = {
  name       = "mamsoft"
  shape      = "VM.Standard.A1.Flex"
  cpus       = 4
  mem_size   = 24
  disk_size  = 200
  image_name = "Canonical-Ubuntu-24.04-aarch64"
  private_ip = "172.16.0.2"

  # SSH public key for VM access.
  # Generate a dedicated key pair with:
  #   ssh-keygen -t ed25519 -f ~/.ssh/oci_mamsoft -C "oci-mamsoft"
  # Then paste the contents of ~/.ssh/oci_mamsoft.pub below.
  ssh_public_keys = [
    "ssh-ed25519 <YOUR_PUBLIC_SSH_KEY> oci-mamsoft"
  ]

  os = {
    hostname = "mamsoft"
    username = "mamsoft"

    # Password hash for sudo access (optional — SSH key auth is sufficient).
    # Generate with: python3 -c 'import crypt; print(crypt.crypt("YOUR_PASSWORD", crypt.mksalt(crypt.METHOD_SHA512)))'
    password = ""

    # Optional: force specific DNS servers (leave as [] to use defaults)
    force_dns = []
    # force_dns = ["1.1.1.1", "1.0.0.1"]

    # Optional WireGuard configuration.
    # Set wg_config = {} (or omit entirely) to disable WireGuard.
    # When non-empty, UDP port 51820 is opened and wireguard-tools is installed.
    wg_config = {}

    # Example WireGuard config (generate keys with: wg genkey | tee privatekey | wg pubkey > publickey):
    # wg_config = {
    #   "wg0" = <<EOF
    # [Interface]
    # PrivateKey = <SERVER_PRIVATE_KEY>
    # Address = 10.200.0.2/32
    # ListenPort = 51820
    # MTU = 1420
    #
    # [Peer]
    # PublicKey = <CLIENT_PUBLIC_KEY>
    # AllowedIPs = 10.200.0.1/32
    # PersistentKeepalive = 25
    # EOF
    # }
  }

  daily_backups  = 3
  weekly_backups = 2
}
